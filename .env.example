# === LLM Provider ===
# Choose one: google, openai, anthropic, ollama
LLM_PROVIDER=google

# API keys (only the one matching your provider is required)
# Google Gemini has a free tier — get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model for your provider
# LLM_MODEL=gemini-2.0-flash

# === Ollama (local models — no API key needed) ===
# Set LLM_PROVIDER=ollama and LLM_MODEL to any model you've pulled
# OLLAMA_BASE_URL=http://localhost:11434/v1   # default
# LLM_MODEL=qwen2.5                           # or: llama3.1, mistral, etc.

# === GitLab ===
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-...
GITLAB_PROJECT_ID=12345
