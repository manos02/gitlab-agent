# === LLM Provider ===
# Choose one: openai, anthropic, google
LLM_PROVIDER=openai

# API keys (only the one matching your provider is required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Optional: override the default model for your provider
# LLM_MODEL=gpt-4o

# === GitLab ===
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-...
GITLAB_PROJECT_ID=12345
