{
  "create_issue": {
    "description": "Create a new issue in the GitLab project. You can set a title, description, labels (comma-separated), and assignees.",
    "parameters": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the issue"
        },
        "description": {
          "type": "string",
          "description": "Markdown body of the issue",
          "default": ""
        },
        "labels": {
          "type": "string",
          "description": "Comma-separated label names, e.g. 'bug,urgent'",
          "default": ""
        }
      },
      "required": ["title"]
    }
  },
  "list_issues": {
    "description": "List issues in the project. Can filter by state (opened/closed/all), labels, search text, or milestone.",
    "parameters": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string",
          "enum": ["opened", "closed", "all"],
          "description": "Filter by issue state",
          "default": "opened"
        },
        "labels": {
          "type": "string",
          "description": "Comma-separated labels to filter by",
          "default": ""
        },
        "search": {
          "type": "string",
          "description": "Search issues by title or description",
          "default": ""
        },
        "milestone": {
          "type": "string",
          "description": "Filter by milestone title",
          "default": ""
        }
      }
    }
  },
  "get_issue": {
    "description": "Get detailed information about a specific issue by its IID (issue number).",
    "parameters": {
      "type": "object",
      "properties": {
        "issue_iid": {
          "type": "integer",
          "description": "The IID (number) of the issue"
        }
      },
      "required": ["issue_iid"]
    }
  },
  "update_issue": {
    "description": "Update an existing issue. Can change title, description, labels, or state.",
    "parameters": {
      "type": "object",
      "properties": {
        "issue_iid": {
          "type": "integer",
          "description": "The IID (number) of the issue to update"
        },
        "title": {
          "type": "string",
          "description": "New title"
        },
        "description": {
          "type": "string",
          "description": "New description (Markdown)"
        },
        "labels": {
          "type": "string",
          "description": "New comma-separated labels (replaces existing)"
        },
        "state_event": {
          "type": "string",
          "enum": ["close", "reopen"],
          "description": "Change issue state"
        }
      },
      "required": ["issue_iid"]
    }
  },
  "close_issue": {
    "description": "Close an issue by its IID.",
    "parameters": {
      "type": "object",
      "properties": {
        "issue_iid": {
          "type": "integer",
          "description": "The IID (number) of the issue to close"
        }
      },
      "required": ["issue_iid"]
    }
  },
  "list_labels": {
    "description": "List all labels available in the project.",
    "parameters": {
      "type": "object",
      "properties": {}
    }
  },
  "create_label": {
    "description": "Create a new label in the project.",
    "parameters": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Label name"
        },
        "color": {
          "type": "string",
          "description": "Hex color code, e.g. '#FF0000'",
          "default": "#428BCA"
        },
        "description": {
          "type": "string",
          "description": "Label description",
          "default": ""
        }
      },
      "required": ["name"]
    }
  },
  "list_merge_requests": {
    "description": "List merge requests in the project. Filter by state or search text.",
    "parameters": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string",
          "enum": ["opened", "closed", "merged", "all"],
          "description": "Filter by MR state",
          "default": "opened"
        },
        "search": {
          "type": "string",
          "description": "Search MRs by title or description",
          "default": ""
        }
      }
    }
  },
  "get_merge_request": {
    "description": "Get detailed information about a specific merge request, including its pipeline status.",
    "parameters": {
      "type": "object",
      "properties": {
        "mr_iid": {
          "type": "integer",
          "description": "The IID (number) of the merge request"
        }
      },
      "required": ["mr_iid"]
    }
  },
  "get_merge_request_pipelines": {
    "description": "Get the list of pipelines for a specific merge request.",
    "parameters": {
      "type": "object",
      "properties": {
        "mr_iid": {
          "type": "integer",
          "description": "The IID of the merge request"
        }
      },
      "required": ["mr_iid"]
    }
  },
  "list_boards": {
    "description": "List all issue boards in the active project or group.",
    "parameters": {
      "type": "object",
      "properties": {}
    }
  },
  "list_board_columns": {
    "description": "List all columns (lists) in a specific board. Each column usually corresponds to a label.",
    "parameters": {
      "type": "object",
      "properties": {
        "board_id": {
          "type": "integer",
          "description": "The ID of the board"
        }
      },
      "required": ["board_id"]
    }
  },
  "move_issue_to_board_column": {
    "description": "Move an issue to a specific board column. In GitLab, board columns map to labels, so this works by adding the target column's label to the issue. You should first list the board columns to find the label name.",
    "parameters": {
      "type": "object",
      "properties": {
        "issue_iid": {
          "type": "integer",
          "description": "The IID of the issue to move"
        },
        "column_label": {
          "type": "string",
          "description": "The label name of the target board column"
        }
      },
      "required": ["issue_iid", "column_label"]
    }
  },
  "search_project": {
    "description": "Search across the project for issues, merge requests, milestones, or other items. Useful for finding things by keyword when you don't know the exact IID.",
    "parameters": {
      "type": "object",
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["issues", "merge_requests", "milestones", "notes", "wiki_blobs"],
          "description": "What to search for"
        },
        "search": {
          "type": "string",
          "description": "Search query text"
        }
      },
      "required": ["scope", "search"]
    }
  },
  "list_milestones": {
    "description": "List milestones (sprints) in the project.",
    "parameters": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string",
          "enum": ["active", "closed"],
          "description": "Filter by milestone state",
          "default": "active"
        }
      }
    }
  },
  "get_group_info": {
    "description": "Get details for the active GitLab group.",
    "parameters": {
      "type": "object",
      "properties": {}
    }
  },
  "list_group_projects": {
    "description": "List projects in the active group, with optional search filter.",
    "parameters": {
      "type": "object",
      "properties": {
        "search": {
          "type": "string",
          "description": "Optional search text for group projects",
          "default": ""
        },
        "include_subgroups": {
          "type": "boolean",
          "description": "Include subgroup projects",
          "default": true
        }
      }
    }
  }
}
